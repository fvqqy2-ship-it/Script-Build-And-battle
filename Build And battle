--// Configuration Settings \\--
local range = 25 -- Increased from 15 to help farm sword kills easily
local autoFarmActive = false

-- Base locations (Homes and Item spawns)
local locations = {
    CFrame.new(-82, 17634, 9046),     -- Epic Katana
    CFrame.new(-95, 17634, 9046),     -- Fusion Coil
    CFrame.new(-124, 17634, 9046),    -- Freeze Ray
    CFrame.new(-110, 17634, 9046)     -- Home 2: Kill Farm Spot
}

-- Matched names for weapon pickup checking
local itemsToProcess = {"Epic Katana", "Freeze Ray", "Fusion Coil"}
local player = game:GetService("Players").LocalPlayer

--// Auto Farm Loop Logic \\--
task.spawn(function()
    while true do
        task.wait(0.1)
        if autoFarmActive and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local humanoidRootPart = player.Character.HumanoidRootPart
            local originalPosition = humanoidRootPart.CFrame
            local backpack = player.Backpack
            local character = player.Character

            -- Teleport to all item spawn points & farming spots
            for _, position in ipairs(locations) do
                if not autoFarmActive then break end
                humanoidRootPart.CFrame = position
                task.wait(0.4) 
            end

            -- Return back to home location
            if autoFarmActive then
                humanoidRootPart.CFrame = originalPosition
                task.wait(0.3)
            end

            -- Unequip all items currently in hand
            for _, tool in ipairs(character:GetChildren()) do
                if tool:IsA("Tool") then
                    tool.Parent = backpack
                end
            end
            task.wait(0.2)

            -- Auto Equip and Drop collected weapons
            for _, toolName in ipairs(itemsToProcess) do
                if not autoFarmActive then break end
                local tool = backpack:FindFirstChild(toolName)
                if tool then
                    tool.Parent = character
                    task.wait(0.1)
                    tool.Parent = game.Workspace
                    task.wait(0.1)
                end
            end
        end
    end
end)

--// Button Toggle \\--
GetAndDropVIP.MouseButton1Down:Connect(function()
    autoFarmActive = not autoFarmActive
    if autoFarmActive then
        GetAndDropVIP.Text = "Auto Farm: ON"
        GetAndDropVIP.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- Green
    else
        GetAndDropVIP.Text = "Auto Farm: OFF"
        GetAndDropVIP.BackgroundColor3 = Color3.fromRGB(0, 0, 255) -- Blue
    end
end)

--// Optimized Rainbow Kill Aura (Sword Hang Uti Auto) \\--
game:GetService("RunService").RenderStepped:Connect(function()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local tool = player.Character:FindFirstChildOfClass("Tool")
    if not tool or not tool:FindFirstChild("Handle") then return end

    local allPlayers = game.Players:GetPlayers()
    for _, targetPlayer in ipairs(allPlayers) do
        if targetPlayer ~= player and targetPlayer.Character then
            local targetChar = targetPlayer.Character
            local targetHrp = targetChar:FindFirstChild("HumanoidRootPart")
            local targetHum = targetChar:FindFirstChild("Humanoid")

            if targetHrp and targetHum and targetHum.Health > 0 then
                local distance = (player.Character.HumanoidRootPart.Position - targetHrp.Position).Magnitude
                if distance <= range then
                    tool:Activate()
                    for _, part in ipairs(targetChar:GetChildren()) do
                        if part:IsA("BasePart") then
                            firetouchinterest(tool.Handle, part, 0)
                            firetouchinterest(tool.Handle, part, 1)
                        end
                    end
                end
            end
        end
    end
end)
